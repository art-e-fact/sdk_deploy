{
    "name": "ROS 2 Humble",
    "build": {
        "dockerfile": "Dockerfile",
        "options": ["--network=host"]
    },
    // Run as your host user so files have correct ownership
    "remoteUser": "root",
    "containerUser": "root",
    // GPU + display access
    "runArgs": [
        "--net=host",
        "--privileged",
        "--env=DISPLAY=${localEnv:DISPLAY}",
        "--env=WAYLAND_DISPLAY=${localEnv:WAYLAND_DISPLAY}",
        "--env=XDG_RUNTIME_DIR=${localEnv:XDG_RUNTIME_DIR}",
        "--volume=/tmp/.X11-unix:/tmp/.X11-unix",
        "--volume=${localEnv:XDG_RUNTIME_DIR}:${localEnv:XDG_RUNTIME_DIR}",
        "--device=/dev/dri"
    ],
    // Source ROS on every shell
    "postCreateCommand": "echo 'source /opt/ros/humble/setup.bash' >> ~/.bashrc && xauth generate ${DISPLAY} . trusted",
    
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-iot.vscode-ros",
                "ms-vscode.cpptools",
                "ms-python.python"
            ]
        }
    }
}
